FROM quay.io/luisarizmendi/ros2-fedora-base:latest

LABEL description="ROS2 Image topic → RTSP/WebRTC streamer via MediaMTX"

# ── Extra dependencies (streamer-specific) ────────────────────────────────────
RUN dnf install -y \
    ros-kilted-cv-bridge \
    python3-opencv \
    ffmpeg \
    curl \
    tar \
    && dnf clean all

# ── MediaMTX ──────────────────────────────────────────────────────────────────
ARG MEDIAMTX_VERSION=v1.9.3
RUN curl -fsSL \
        "https://github.com/bluenviron/mediamtx/releases/download/${MEDIAMTX_VERSION}/mediamtx_${MEDIAMTX_VERSION}_linux_amd64.tar.gz" \
        | tar -xz -C /usr/local/bin mediamtx \
    && chmod +x /usr/local/bin/mediamtx

RUN mkdir -p /etc/mediamtx
COPY mediamtx.yml /etc/mediamtx/mediamtx.yml

# ── ROS2 package ──────────────────────────────────────────────────────────────
WORKDIR /ros2_ws/src/image_streamer
COPY ros2_pkg/ ./

WORKDIR /ros2_ws
RUN /bin/bash -c "source /usr/lib64/ros2-kilted/setup.bash && colcon build --symlink-install"

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# ── Environment defaults ──────────────────────────────────────────────────────
ENV RTSP_HOST=127.0.0.1
ENV RTSP_PORT=8554
ENV RTSP_NAME=stream
ENV VIDEO_CODEC=libx264
ENV VIDEO_BITRATE=1000k
ENV VIDEO_PRESET=ultrafast
ENV VIDEO_TUNE=zerolatency
ENV TARGET_FPS=30
ENV IMAGE_WIDTH=0
ENV IMAGE_HEIGHT=0
ENV ROS_TOPIC=/camera/image_raw
ENV ROS_DOMAIN_ID=0

# ── Ports ─────────────────────────────────────────────────────────────────────
# 8554  → RTSP
# 8888  → HLS  (web player)
# 8889  → WebRTC (web player)
# 8189  → WebRTC ICE UDP mux
EXPOSE 8554
EXPOSE 8888
EXPOSE 8889
EXPOSE 8189/udp

ENTRYPOINT ["/entrypoint.sh"]
