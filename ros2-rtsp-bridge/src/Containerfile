FROM ros2-fedora-base:latest

# ── Bridge-specific dependencies ──────────────────────────────────────────────
RUN dnf install -y \
    ros-kilted-cv-bridge \
    python3-opencv \
    gstreamer1 \
    gstreamer1-plugins-base \
    gstreamer1-plugins-base-tools \
    gstreamer1-plugins-good \
    gstreamer1-plugins-bad-free \
    gstreamer1-plugins-ugly-free \
    && dnf clean all

# ── ROS2 package ──────────────────────────────────────────────────────────────
WORKDIR /ros2_ws/src/rtsp_bridge
COPY ros2_pkg/ ./

WORKDIR /ros2_ws
RUN /bin/bash -c "source /usr/lib64/ros2-kilted/setup.bash && colcon build --symlink-install"

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["ros2", "run", "rtsp_bridge", "rtsp_bridge_node"]
